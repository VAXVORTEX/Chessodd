static func set_locale(l: String):
	lang = l
	Engine.get_main_loop().root.get_tree().call_group("translateable", "update_translation")

static func translate(key: String, vars: Array = []) -> String:
	var res = key
	if dict.has(lang) and dict[lang].has(key):
		res = dict[lang][key]
		
	for i in range(vars.size()):
		res = res.replace("{%d}" % i, str(vars[i]))
		
	return res
